{
  "info": {
    "name": "replime",
    "_postman_id": "replime-collection",
    "description": "RepliMe Backend APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "localhost:8080/api/v1"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"testuser\",\n  \"email\": \"test@test.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "signup"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"token\", jsonData.token);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@test.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"token\", jsonData.token);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Admin Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"admin\",\n  \"email\": \"admin@test.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup/admin",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "signup", "admin"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"token\", jsonData.token);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Influencer Verification",
      "item": [
        {
          "name": "Request Verification",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"channelUrl\": \"https://youtube.com/@example\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/influencer/verify/request",
              "host": ["{{baseUrl}}"],
              "path": ["influencer", "verify", "request"]
            }
          }
        },
        {
          "name": "Confirm Verification",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/influencer/verify/confirm",
              "host": ["{{baseUrl}}"],
              "path": ["influencer", "verify", "confirm"]
            }
          }
        }
      ]
    },
    {
      "name": "Public Chatbot",
      "item": [
        {
          "name": "Get All Public Chatbots",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/chatbots",
              "host": ["{{baseUrl}}"],
              "path": ["chatbots"]
            }
          }
        },
        {
          "name": "Get Chatbot By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/chatbots/{{chatbotId}}",
              "host": ["{{baseUrl}}"],
              "path": ["chatbots", "{{chatbotId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin Chatbot",
      "item": [
        {
          "name": "Get All Chatbots (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/chatbots",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "chatbots"]
            }
          }
        },
        {
          "name": "Update Chatbot Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/chatbots/{{chatbotId}}/status?status=ACTIVE",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "chatbots", "{{chatbotId}}", "status"],
              "query": [
                {
                  "key": "status",
                  "value": "ACTIVE"
                }
              ]
            }
          }
        },
        {
          "name": "Update Chatbot Visibility",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/chatbots/{{chatbotId}}/visibility?isPublic=true",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "chatbots", "{{chatbotId}}", "visibility"],
              "query": [
                {
                  "key": "isPublic",
                  "value": "true"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Influencer Chatbot",
      "item": [
        {
          "name": "Get Chatbot Config",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/influencer/chatbot",
              "host": ["{{baseUrl}}"],
              "path": ["influencer", "chatbot"]
            }
          }
        },
        {
          "name": "Save Chatbot Config",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Chatbot\",\n  \"description\": \"A test chatbot\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/influencer/chatbot/config",
              "host": ["{{baseUrl}}"],
              "path": ["influencer", "chatbot", "config"]
            }
          }
        },
        {
          "name": "Update Chatbot Config",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Chatbot\",\n  \"description\": \"Updated description\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/influencer/chatbot/config",
              "host": ["{{baseUrl}}"],
              "path": ["influencer", "chatbot", "config"]
            }
          }
        }
      ]
    }
  ]
}